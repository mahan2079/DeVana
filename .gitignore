# ============================================================
# DeVana — .gitignore
# ============================================================

# ----------------------------------------------------------
# Python — bytecode & caches
# ----------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo

# ----------------------------------------------------------
# Python — build & distribution
# ----------------------------------------------------------
build/
dist/
*.egg-info/
*.egg
.eggs/
wheels/
sdist/
develop-eggs/
parts/
var/
bin/
lib/
lib64/
.installed.cfg

# ----------------------------------------------------------
# Python — testing & coverage
# ----------------------------------------------------------
.coverage
.coverage.*
coverage.xml
*.cover
htmlcov/
.tox/
.nox/
.cache
.hypothesis/
nosetests.xml
.pytest_cache/

# ----------------------------------------------------------
# Python — type checking & linting
# ----------------------------------------------------------
.mypy_cache/
.pytype/
.pyre/
.ruff_cache/

# ----------------------------------------------------------
# Python — virtual environments
# ----------------------------------------------------------
.env
.venv
venv/
venv_api/
ENV/
env/
env.bak/
venv.bak/
.python-version

# ----------------------------------------------------------
# Python — packaging & build tools
# ----------------------------------------------------------
*.manifest
*.spec
pip-log.txt
pip-delete-this-directory.txt
*.mo
*.pot
*.sage.py
celerybeat-schedule

# ----------------------------------------------------------
# Jupyter
# ----------------------------------------------------------
.ipynb_checkpoints/

# ----------------------------------------------------------
# Secrets & local configuration
# ----------------------------------------------------------
api_keys.json
*.secret
.env.local
.env.*.local

# ----------------------------------------------------------
# Project-specific generated files
# ----------------------------------------------------------
# Temporary images generated during documentation builds
temp_images/
# Large compiled documentation artifacts (kept in Documents/)
DeVana_Master_Documentation.html
DeVana_Master_Documentation.md
DeVana_Professional_Documentation.pdf
DeVana_Sovereign_Documentation.pdf
# One-off documentation / utility scripts
fix_mermaid.py
generate_mixin_docs.py
generate_pro_pdf.py
mega_documenter.py
mega_synthesis.py
merge_to_pdf.py
mermaid_syncer.py
# Runtime outputs
results/
logs/
*.log

# ----------------------------------------------------------
# Editor & IDE settings
# ----------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.spyderproject
.spyproject
.ropeproject
# Obsidian vault settings (inside Documents/)
Documents/.obsidian/

# ----------------------------------------------------------
# OS-generated files
# ----------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ----------------------------------------------------------
# Documentation build artefacts
# ----------------------------------------------------------
docs/_build/
/site

# ----------------------------------------------------------
# C extensions
# ----------------------------------------------------------
*.so

# ----------------------------------------------------------
# Paper exceptions (keep tracked)
# ----------------------------------------------------------
!paper/paper.bib
!paper/paper.md
